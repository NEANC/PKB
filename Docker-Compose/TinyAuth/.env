# tinyauth 配置

# 反代地址
APP_URL=https://tinyauth.example.com

# 自定义内容
# 登录页面标题
APP_TITLE=欢迎访问 Tinyauth SSO
# 忘记密码提示
FORGOT_PASSWORD_MESSAGE="lol"
# 背景图片
# BACKGROUND_IMAGE=<地址>/background.png

# cookie 设置
# 设置是否仅通过安全连接发送 Cookie
SECURE_COOKIE=true
# cookie 过期时间，单位为秒，当前为 7 天
SESSION_EXPIRY=604800

# tinyauth 自托管密码配置
# 运行命令生成加密后的密码：echo $(openssl 密码 -nB 用户名) | sed -e s/\$/\$\$/g
USERS=<用户>:<加密后的密码>
# 最大尝试次数
LOGIN_MAX_RETRIES=3
# 登陆错误后需要等待再试时间，单位为秒，当前为 5 分钟
LOGIN_TIMEOUT=300

# Pocket ID 设置
# 显示在登录页面上的名称
PROVIDERS_POCKETID_NAME=Pocket ID
# Pocket ID 客户端ID
POCKETID_CLIENT_ID=your-pocket-id-client-id
# Pocket ID 客户端密钥
POCKETID_CLIENT_SECRET=your-pocket-id-client-secret
# Pocket ID 认证 URL
POCKETID_AUTH_URL=https://pocketid.example.com/authorize
# Pocket ID 令牌 URL
POCKETID_TOKEN_URL=https://pocketid.example.com/api/oidc/token
# Pocket ID 用户信息 URL
POCKETID_USER_INFO_URL=https://pocketid.example.com/api/oidc/userinfo
# Pocket ID 回调URL
POCKETID_REDIRECT_URL=https://tinyauth.example.com/api/oauth/callback/pocketid
# Pocket ID 作用域，无需修改
POCKETID_SCOPES=openid email profile groups

# 白名单，指定允许登录的电子邮件地址
# OAUTH_WHITELIST=<邮箱1>,<邮箱2>

# ACL/访问控制 配置
# 请修改 [APP] 为实际应用名称
# TINYAUTH_APPS_[APP]_CONFIG_DOMAIN=<应用域名>
# 来着 OAuth 的、指定的邮箱地址列表或正则表达式。
# TINYAUTH_APPS_[APP]_OAUTH_WHITELIST=<允许登录的邮箱1>,<允许登录的邮箱2>
# 允许用户访问该应用的白名单，也适用于来着 LDAP 的用户。
# TINYAUTH_APPS_[APP]_USERS_ALLOW=user1,user2
# 限制用户访问该应用的黑名单，也适用于来着 LDAP 的用户。
# TINYAUTH_APPS_[APP]_USERS_BLOCK=user3,user4


# 使用 OIDC 组进行访问控制
# 某些 OIDC 服务器（如 Pocket ID）支持在 OIDC 响应中包含用户组。若要使用用户组，请确保在 OAuth 提供商配置中包含 groups 作用域。
# 注意：该标签仅适用于自定义 OAuth 提供商，不适用于 Google 或 GitHub
# TINYAUTH_APPS_[APP]_OAUTH_GROUPS=admin

# 基于 IP 的访问控制
# 允许访问的 IP 地址或子网，逗号分隔
# TINYAUTH_APPS_[APP]_IP_ALLOW: 10.10.5.5,10.10.10.0/24
# 禁止访问的 IP 地址或子网，逗号分隔
# TINYAUTH_APPS_[APP]_IP_BLOCK: 192.168.1.1,192.168.0.0/16
# 禁用特定 IP 地址或子网的身份验证，逗号分隔
# TINYAUTH_APPS_[APP]_IP_BYPASS: 10.10.5.5,10.10.10.0/24

# --------------------------
# 示例：配置两个应用，网页1 仅允许 user10 访问，网页2 禁止 user10 访问

# 网页1（仅允许 user10 访问）
# TINYAUTH_APPS_WEB1_CONFIG_DOMAIN=shturl.cc/5gPyrZlziv
# TINYAUTH_APPS_WEB1_OAUTH_WHITELIST=user10

# 网页2
# TINYAUTH_APPS_WEB2_CONFIG_DOMAIN=shturl.cc/ZLALG82hIA
# TINYAUTH_APPS_WEB2_OAUTH_BLOCK=user10
# --------------------------

# 时区设置
TZ=Asia/Shanghai