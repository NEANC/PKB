# RustDesk-API 配置

# 时区设置
TZ=Asia/Shanghai

# 中续节点，复数使用逗号分隔，不需要添加 http:// 或 https://，可使用域名或 IP 地址
RELAY=服务器IP:21117

# rustdesk API 配置
# 若使用反代，请使用 example.com:21116
RUSTDESK_API_RUSTDESK_ID_SERVER=服务器IP:21116
# 若使用反代，请使用 example.com:21117
RUSTDESK_API_RUSTDESK_RELAY_SERVER=服务器IP:21117
# 若使用反代，请使用 https://example.com；对应 21114 端口
RUSTDESK_API_RUSTDESK_API_SERVER=https://example.com

# 不接受未加密的连接
ENCRYPTED_ONLY=1

# 安全性
# 是否启用注册功能，建议创建管理员账户后设置为 false
RUSTDESK_API_APP_REGISTER=true
# 是否禁用密码登录功能
# RUSTDESK_API_APP_DISABLE_PWD_LOGIN=true
# 是否启用 Webclient2；0为关闭，1为开启；推荐关闭，避免安全风险
RUSTDESK_API_APP_WEB_CLIENT=0
# 公钥文件存放位置，可以在 Docker 容器日志查找
RUSTDESK_API_KEY_FILE=./data/id_ed25519.pub
# 自定义公钥密码，不建议使用，若使用请使用该命令生成：openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32
# RUSTDESK_API_RUSTDESK_KEY=
# 客户端账号登陆过期时间，默认为七天未使用就登出账号，支持h,m,s
RUSTDESK_API_APP_TOKEN_EXPIRE=168h


# 界面相关
# 是否在界面显示 Swagger 文档，建议生产环境关闭；0为关闭，1为开启
# RUSTDESK_API_APP_SHOW_SWAGGER=1
# 控制台标题
RUSTDESK_API_ADMIN_TITLE=RustDesk 控制台

# JWT 控制相关，若使用MUST_LOGIN，则必须设置JWT_KEY
# 是否必须登录，N为不启用，Y为启用；配合RUSTDESK_API_JWT_KEY，设置后会通过JWT校验token的合法性
MUST_LOGIN=N
#- RUSTDESK_API_JWT_KEY=xxxxxx #自定义JWT KEY,为空则不启用JWT，若不使用MUST_LOGIN，建议设置为空
#- RUSTDESK_API_JWT_EXPIRE_DURATION=168h #JWT有效时间，支持h,m,s

# 带宽限制
# hbbr 速度限制（以Mb/s为单位）
LIMIT_SPEED=20
# hbbr 单个连接的最大带宽（以Mb/s为单位）
SINGLE_BANDWIDTH=12
# hbbr 总带宽（以Mb/s为单位）
TOTAL_BANDWIDTH=20