# 1. 自动识别所有文本文件，强制使用 LF
* text=auto eol=lf

# 2. 针对特定脚本/配置文件显式指定（更保险）
*.sh         text eol=lf
*.toml       text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.service    text eol=lf
*.md         text eol=lf
*.txt        text eol=lf

# 3. 明确标记二进制文件（禁止转换换行符，防止文件损坏）
*.jpg        binary
*.jpeg       binary
*.png        binary
*.gif        binary